# AI Sandbox Container
# Isolated environment for running AI coding agents (Claude Code, Codex, Gemini CLI)
# with full code access but no host secrets.
FROM registry.fedoraproject.org/fedora:41

RUN dnf install -y \
    git \
    curl \
    nodejs \
    npm \
    python3 \
    python3-pip \
    golang \
    make \
    jq \
    ripgrep \
    fd-find \
    && dnf clean all

# AI CLI tools installed globally via npm
RUN npm install -g \
    @anthropic-ai/claude-code \
    @openai/codex \
    @google/gemini-cli

# Non-root user (UID mapped via --userns=keep-id at runtime)
RUN useradd -m -s /bin/bash sandbox

WORKDIR /workspace
USER sandbox
CMD ["/bin/bash"]
