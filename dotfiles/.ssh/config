# SSH Configuration
# Managed by provision-laptop — edits will be overwritten.

# Use 1Password SSH agent for all connections
Host *
    IdentityAgent "~/.1password/agent.sock"
    AddKeysToAgent yes
    ForwardAgent no
    HashKnownHosts yes
    ServerAliveInterval 60
    ServerAliveCountMax 3

# GitHub
Host github.com
    HostName github.com
    User git
