#!/usr/bin/env bash
# s2idle-debug — Run AMD s2idle diagnostics to identify sleep blockers.
#
# Installs amd-debug-tools via pip and runs amd_s2idle. Requires root
# (sudo) — performs a timed suspend cycle and reports which devices or
# constraints prevent the system from reaching the deepest S0ix sleep state.
#
# Prerequisites: mise with Python configured (see mise/mise.toml)
#
# Usage:
#   bin/s2idle-debug              Run diagnostics (suspends briefly)
#   bin/s2idle-debug --help       Show amd_s2idle help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROVISION_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=../lib/common.sh
source "${PROVISION_DIR}/lib/common.sh"

ensure_python() {
    # Activate mise if available but not yet in PATH
    if ! command -v python3 &>/dev/null && command -v mise &>/dev/null; then
        eval "$(mise activate bash)"
    fi

    if ! command -v python3 &>/dev/null; then
        log_error "Python 3 not found — run 'bin/apply --module mise' first"
        exit 1
    fi

    # Bootstrap pip if missing (mise-built Python has ensurepip but pip isn't bootstrapped by default)
    if ! python3 -m pip --version &>/dev/null 2>&1; then
        log_info "Bootstrapping pip..."
        python3 -m ensurepip --upgrade
    fi
}

ensure_installed() {
    # Check if the package is importable
    if python3 -c "import amd_debug.s2idle" &>/dev/null 2>&1; then
        return 0
    fi

    log_info "Installing amd-debug-tools..."
    python3 -m pip install amd-debug-tools
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

if [[ "$(uname)" == "Darwin" ]]; then
    log_error "This tool only works on Linux (AMD systems with s2idle support)"
    exit 1
fi

ensure_python
ensure_installed

log_info "Running AMD s2idle diagnostics (this will briefly suspend the system)..."
echo

sudo "$(command -v python3)" -m amd_debug.s2idle "$@"
