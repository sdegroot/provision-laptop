#!/usr/bin/env bash
# s2idle-debug — Run AMD s2idle diagnostics to identify sleep blockers.
#
# Clones amd-debug-tools and runs amd_s2idle. Requires root (sudo) —
# performs a timed suspend cycle and reports which devices or constraints
# prevent the system from reaching the deepest S0ix sleep state.
#
# Usage:
#   bin/s2idle-debug              Run diagnostics (suspends briefly)
#   bin/s2idle-debug --help       Show amd_s2idle help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROVISION_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=../lib/common.sh
source "${PROVISION_DIR}/lib/common.sh"

CACHE_DIR="${HOME}/.cache/provision-laptop"
REPO_DIR="${CACHE_DIR}/amd-debug-tools"
REPO_URL="https://gitlab.freedesktop.org/drm/amd-debug-tools.git"

ensure_repo() {
    mkdir -p "$CACHE_DIR"

    if [[ -d "$REPO_DIR" ]]; then
        # Pull if older than 7 days
        local age_days
        age_days=$(( ($(date +%s) - $(stat -c %Y "$REPO_DIR/.git/FETCH_HEAD" 2>/dev/null || echo 0)) / 86400 ))
        if [[ $age_days -ge 7 ]]; then
            log_info "Updating amd-debug-tools..."
            git -C "$REPO_DIR" pull --quiet 2>/dev/null || log_warn "Pull failed, using cached version"
        fi
    else
        log_info "Cloning amd-debug-tools..."
        if ! git clone --depth 1 --quiet "$REPO_URL" "$REPO_DIR"; then
            log_error "Failed to clone amd-debug-tools"
            exit 1
        fi
    fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

if [[ "$(uname)" == "Darwin" ]]; then
    log_error "This tool only works on Linux (AMD systems with s2idle support)"
    exit 1
fi

ensure_repo

log_info "Running AMD s2idle diagnostics (this will briefly suspend the system)..."
echo

sudo PYTHONPATH="$REPO_DIR/src" python3 -m amd_debug.s2idle "$@"
