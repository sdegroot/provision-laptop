#!/usr/bin/env bash
# s2idle-debug — Run AMD s2idle diagnostics to identify sleep blockers.
#
# Installs amd-debug-tools via pip (from mise-managed Python) and runs
# amd_s2idle. Requires root (sudo) — performs a timed suspend cycle and
# reports which devices or constraints prevent the system from reaching
# the deepest S0ix sleep state.
#
# Prerequisites: mise with Python configured (see mise/mise.toml)
#
# Usage:
#   bin/s2idle-debug              Run diagnostics (suspends briefly)
#   bin/s2idle-debug --help       Show amd_s2idle help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROVISION_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=../lib/common.sh
source "${PROVISION_DIR}/lib/common.sh"

ensure_python() {
    if command -v python3 &>/dev/null; then
        return 0
    fi

    # Activate mise if available but not yet in PATH
    if command -v mise &>/dev/null; then
        log_info "Activating mise to get Python..."
        eval "$(mise activate bash)"
    fi

    if ! command -v python3 &>/dev/null; then
        log_error "Python 3 not found — run 'bin/apply --module mise' first to install mise and Python"
        exit 1
    fi
}

ensure_installed() {
    if command -v amd_s2idle &>/dev/null; then
        return 0
    fi

    log_info "Installing amd-debug-tools..."
    if command -v pipx &>/dev/null; then
        pipx install amd-debug-tools
    else
        python3 -m pip install --user amd-debug-tools
    fi

    # Ensure ~/.local/bin is in PATH for the freshly installed command
    if ! command -v amd_s2idle &>/dev/null; then
        export PATH="${HOME}/.local/bin:${PATH}"
    fi

    if ! command -v amd_s2idle &>/dev/null; then
        log_error "amd-debug-tools installed but amd_s2idle not found in PATH"
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

if [[ "$(uname)" == "Darwin" ]]; then
    log_error "This tool only works on Linux (AMD systems with s2idle support)"
    exit 1
fi

ensure_python
ensure_installed

log_info "Running AMD s2idle diagnostics (this will briefly suspend the system)..."
echo

sudo amd_s2idle "$@"
