#!/usr/bin/env bash
# s2idle-debug — Run AMD s2idle diagnostics to identify sleep blockers.
#
# Installs amd-debug-tools via pipx and runs amd_s2idle. Requires root
# (sudo) — performs a timed suspend cycle and reports which devices or
# constraints prevent the system from reaching the deepest S0ix sleep state.
#
# Usage:
#   bin/s2idle-debug              Run diagnostics (suspends briefly)
#   bin/s2idle-debug --help       Show amd_s2idle help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROVISION_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=../lib/common.sh
source "${PROVISION_DIR}/lib/common.sh"

ensure_installed() {
    if command -v amd_s2idle &>/dev/null; then
        return 0
    fi

    if ! command -v pipx &>/dev/null; then
        log_error "pipx is required — install it with: sudo dnf install pipx"
        exit 1
    fi

    log_info "Installing amd-debug-tools via pipx..."
    pipx install amd-debug-tools
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

if [[ "$(uname)" == "Darwin" ]]; then
    log_error "This tool only works on Linux (AMD systems with s2idle support)"
    exit 1
fi

ensure_installed

log_info "Running AMD s2idle diagnostics (this will briefly suspend the system)..."
echo

sudo amd_s2idle "$@"
