#!/usr/bin/env bash
# s2idle-debug — Run AMD s2idle diagnostics to identify sleep blockers.
#
# Installs amd-debug-tools via pip and runs amd_s2idle. Requires root
# (sudo) — performs a timed suspend cycle and reports which devices or
# constraints prevent the system from reaching the deepest S0ix sleep state.
#
# Prerequisites: mise (https://mise.jdx.dev) — Python is managed via .mise.toml
#
# Usage:
#   bin/s2idle-debug              Run a single test cycle (suspends briefly)
#   bin/s2idle-debug test --count 3  Run 3 test cycles
#   bin/s2idle-debug report       Generate report from previous captures
#   bin/s2idle-debug --help       Show amd_s2idle help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROVISION_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=../lib/common.sh
source "${PROVISION_DIR}/lib/common.sh"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

mise_exec() {
    # Run a command using the mise-managed Python from .mise.toml.
    # This works regardless of whether mise is "activated" in the shell.
    mise exec --cd "$PROVISION_DIR" python -- "$@"
}

ensure_mise() {
    if ! command -v mise &>/dev/null; then
        log_error "mise is not installed — see https://mise.jdx.dev for installation"
        exit 1
    fi
}

ensure_installed() {
    # Check if amd-s2idle is already available in the mise Python environment
    if mise_exec python3 -c "import shutil; exit(0 if shutil.which('amd-s2idle') else 1)" 2>/dev/null; then
        return 0
    fi

    log_info "Installing amd-debug-tools..."
    mise_exec python3 -m pip install amd-debug-tools

    if ! mise_exec python3 -c "import shutil; exit(0 if shutil.which('amd-s2idle') else 1)" 2>/dev/null; then
        log_error "amd-debug-tools installed but amd-s2idle entry point not found"
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

if [[ "$(uname)" == "Darwin" ]]; then
    log_error "This tool only works on Linux (AMD systems with s2idle support)"
    exit 1
fi

ensure_mise
ensure_installed

# Resolve the absolute path to amd-s2idle so sudo can find it
AMD_S2IDLE="$(mise_exec python3 -c "import shutil; print(shutil.which('amd-s2idle'))")"

# Default to "test" subcommand when called with no arguments
if [[ $# -eq 0 ]]; then
    set -- test
fi

log_info "Running: amd-s2idle $*"
echo

sudo "$AMD_S2IDLE" "$@"
