// Allow 1Password SSH agent and CLI to operate without repeated prompts
// when the user is logged in and 1Password is unlocked.
polkit.addRule(function(action, subject) {
    if ((action.id === "com.1password.1Password.authorizeSshAgent" ||
         action.id === "com.1password.1Password.authorizeCLI") &&
        subject.local && subject.active) {
        return polkit.Result.YES;
    }
});
